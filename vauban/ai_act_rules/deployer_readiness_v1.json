      "relevance": "Legal text for Articles 5, 6, 27, 50 and Annex I/III use-case triggers"
    }
  ],
  "controls": [
    {
      "control_id": "scope.minimum_facts",
      "title": "Minimum factual scope for the report",
      "source_type": "vauban_readiness",
      "source_ref": "Vauban readiness v1",
      "description": "The customer supplied enough facts to avoid a fabricated scope.",
      "applies_when": "Always.",
      "source_ids": [],
      "evidence_required": ["company_name", "system_name", "intended_purpose"],
      "check_method": "Config presence check.",
      "blocking": true
    },
    {
      "control_id": "ai_act.article4.ai_literacy_record",
      "title": "Article 4 AI literacy evidence",
      "source_type": "ai_act",
      "source_ref": "Article 4 AI Act",
      "description": "A sufficient AI literacy record exists for staff or persons operating the system on the deployer's behalf.",
      "applies_when": "EU-market operation outside research-only scope.",
      "source_ids": [
        "commission_ai_literacy_qa",
        "commission_ai_literacy_policy",
        "eurlex_ai_act_regulation"
      ],
      "evidence_required": [
        "AI literacy record",
        "owner/contact",
        "target roles or persons",
        "organisation role in relation to the AI system",
        "system or use-context coverage",
        "risk or limitation coverage",
        "training date or recency",
        "scope or materials",
        "refresh cadence"
      ],
      "check_method": "File presence plus minimum content markers.",
      "blocking": true
    },
    {
      "control_id": "ai_act.article5.prohibited_practices_screen",
      "title": "Article 5 prohibited-practices screen",
      "source_type": "ai_act",
      "source_ref": "Article 5 AI Act",
      "description": "Screen declared facts for obvious prohibited-practice scenarios such as emotion recognition in workplace/education without the medical or safety exception, or biometric categorisation inferring sensitive traits.",
      "applies_when": "EU-market operation outside research-only scope.",
      "source_ids": [
        "eurlex_ai_act_regulation",
        "commission_navigating_ai_act"
      ],
      "evidence_required": [
        "Declared emotion-recognition or biometric-categorisation facts",
        "declared workplace/education context",
        "declared exception facts where relevant"
      ],
      "check_method": "Rule-based screen from customer assertions.",
      "blocking": true
    },
    {
      "control_id": "ai_act.article50.human_interaction_notice",
      "title": "Article 50 transparency for human interaction",
      "source_type": "ai_act",
      "source_ref": "Article 50 AI Act",
      "description": "When the system interacts with natural persons and the AI nature is not obvious, transparency evidence should exist.",
      "applies_when": "EU-market operation with declared provider/modifier role and direct human interaction that is not obvious to exposed persons.",
      "source_ids": [
        "commission_transparent_ai_qa",
        "commission_navigating_ai_act",
        "eurlex_ai_act_regulation"
      ],
      "evidence_required": [
        "Transparency notice",
        "AI/automated origin statement",
        "interaction context marker",
        "not-human or bot disclosure"
      ],
      "check_method": "File presence plus minimum content markers.",
      "blocking": true
    },
    {
      "control_id": "ai_act.article50.emotion_biometric_notice",
      "title": "Article 50 transparency for emotion or biometric exposure",
      "source_type": "ai_act",
      "source_ref": "Article 50 AI Act",
      "description": "When people are exposed to emotion recognition or biometric categorization, transparency evidence should exist.",
      "applies_when": "EU-market operation with declared emotion-recognition or biometric-categorization exposure.",
      "source_ids": [
        "commission_transparent_ai_qa",
        "commission_navigating_ai_act",
        "eurlex_ai_act_regulation"
      ],
      "evidence_required": [
        "Transparency notice",
        "emotion or biometric terminology",
        "notification/disclosure language"
      ],
      "check_method": "File presence plus minimum content markers.",
      "blocking": true
    },
    {
      "control_id": "ai_act.article50.deepfake_disclosure",
      "title": "Article 50 deployer disclosure for deepfake or synthetic media",
      "source_type": "ai_act",
      "source_ref": "Article 50 AI Act",
      "description": "When deployers expose people to deepfake or synthetic media, disclosure evidence must exist.",
      "applies_when": "EU-market operation with declared synthetic-media exposure.",
      "source_ids": [
        "commission_transparent_ai_qa",
        "commission_transparent_ai_consultation",
        "eurlex_ai_act_regulation"
      ],
      "evidence_required": [
        "Transparency notice",
        "AI/automated origin statement",
        "deepfake/synthetic/manipulated content marker",
        "if relying on the creative/satirical/artistic/fictional context, appropriate existence disclosure"
      ],
      "check_method": "File presence plus minimum content markers.",
      "blocking": true
    },
    {
      "control_id": "ai_act.article50.public_interest_text_disclosure",
      "title": "Article 50 deployer disclosure for public-interest text",
      "source_type": "ai_act",
      "source_ref": "Article 50 AI Act",
      "description": "When deployers publish AI-generated text on matters of public interest, disclosure evidence must exist.",
      "applies_when": "EU-market operation with declared public-interest text publication.",
      "source_ids": [
        "commission_transparent_ai_qa",
        "commission_transparent_ai_consultation",
        "eurlex_ai_act_regulation"
      ],
      "evidence_required": [
        "Transparency notice",
        "AI/automated origin statement",
        "public-facing publication marker",
        "or evidence of human review/editorial control plus editorial responsibility when relying on the Article 50 exception"
      ],
      "check_method": "File presence plus minimum content markers.",
      "blocking": true
    },
    {
      "control_id": "ai_act.triage.high_risk_annex_iii",
      "title": "High-risk and FRIA triage",
      "source_type": "ai_act",
      "source_ref": "Article 6 / Annex I / Annex III",
      "description": "Flag likely Annex I product-route or Annex III high-risk uses for legal review. Vauban does not auto-classify these as legally settled facts.",
      "applies_when": "EU-market operation outside research-only scope.",
      "source_ids": [
        "commission_navigating_ai_act",
        "eurlex_ai_act_regulation"
      ],
      "evidence_required": [
        "Declared intended purpose",
        "declared sector and use-context flags"
      ],
      "check_method": "Rule-based triage from customer assertions.",
      "blocking": true
    },
    {
      "control_id": "ai_act.triage.article6_3_annex_iii_carve_out",
      "title": "Article 6(3) Annex III carve-out triage",
      "source_type": "ai_act",
      "source_ref": "Article 6(3) AI Act",
      "description": "Review declared Annex III carve-out facts for narrow procedural, preparatory, or similarly low-impact tasks that may avoid high-risk classification if the system does not materially influence decision outcomes.",
      "applies_when": "EU-market operation outside research-only scope with a declared Annex III use case.",
      "source_ids": [
        "commission_navigating_ai_act",
        "eurlex_ai_act_regulation"
      ],
      "evidence_required": [
        "Declared Annex III use cases",
        "declared Article 6(3) carve-out conditions",
        "declared no-material-influence fact",
        "declared profiling fact where relevant"
      ],
      "check_method": "Rule-based triage from customer assertions.",
      "blocking": true
    },
    {
      "control_id": "ai_act.triage.fria_requirement",
      "title": "FRIA triage",
      "source_type": "ai_act",
      "source_ref": "Article 27 AI Act",
      "description": "Flag declared scenarios that may trigger a deployer fundamental-rights impact assessment.",
      "applies_when": "EU-market operation outside research-only scope.",
      "source_ids": [
        "commission_navigating_ai_act",
        "eurlex_ai_act_regulation"
      ],
      "evidence_required": [
        "Declared public-sector or public-service context",
        "declared Annex III point 5(b)/(c) facts where relevant"
      ],
      "check_method": "Rule-based triage from customer assertions.",
      "blocking": true
    },
    {
      "control_id": "ai_act.article26.instructions_monitoring",
      "title": "Article 26 instructions-of-use and monitoring",
      "source_type": "ai_act",
      "source_ref": "Article 26 AI Act",
      "description": "High-risk deployers should retain provider instructions and operational monitoring evidence showing how they use and monitor the system in practice.",
      "applies_when": "Declared EU-market high-risk deployer scenario.",
      "source_ids": [
        "commission_navigating_ai_act",
        "eurlex_ai_act_regulation"
      ],
      "evidence_required": [
        "Provider documentation or instructions for use",
        "operation monitoring procedure",
        "risk or incident escalation path",
        "operator or oversight assignment"
      ],
      "check_method": "File presence plus minimum content markers.",
      "blocking": true
    },
    {
      "control_id": "ai_act.article26.human_oversight",
      "title": "Article 26 human oversight",
      "source_type": "ai_act",
      "source_ref": "Article 26 AI Act",
      "description": "High-risk deployers should document how a sufficiently equipped person or persons exercise human oversight in operation.",
      "applies_when": "Declared EU-market high-risk deployer scenario.",
      "source_ids": [
        "commission_navigating_ai_act",
        "eurlex_ai_act_regulation"
      ],
      "evidence_required": [
        "Human oversight procedure",
        "review or override step",
        "handoff or escalation trigger",
        "named owner or responsible person"
      ],
      "check_method": "File presence plus minimum content markers.",
      "blocking": true
    },
    {
      "control_id": "ai_act.article26.input_data_governance",
      "title": "Article 26 input-data governance",
      "source_type": "ai_act",
      "source_ref": "Article 26 AI Act",
      "description": "Where deployers provide input data to a high-risk AI system, they should document relevance and representativeness controls for those inputs.",
      "applies_when": "Declared EU-market high-risk deployer scenario with deployer-provided input data.",
      "source_ids": [
        "commission_navigating_ai_act",
        "eurlex_ai_act_regulation"
      ],
      "evidence_required": [
        "Input data governance procedure",
        "relevance criteria",
        "representativeness or quality checks"
      ],
      "check_method": "File presence plus minimum content markers.",
      "blocking": true
    },
    {
      "control_id": "ai_act.article26.log_retention",
      "title": "Article 26 log retention",
      "source_type": "ai_act",
      "source_ref": "Article 26 AI Act",
      "description": "High-risk deployers should retain logs under their control for an appropriate period, with the six-month baseline reflected in the procedure.",
      "applies_when": "Declared EU-market high-risk deployer scenario.",
      "source_ids": [
        "commission_navigating_ai_act",
        "eurlex_ai_act_regulation"
      ],
      "evidence_required": [
        "Log retention procedure",
        "retention period",
        "control or access scope"
      ],
      "check_method": "File presence plus minimum content markers.",
      "blocking": true
    },
    {
      "control_id": "ai_act.article26.workplace_notice",
      "title": "Article 26 workplace information duty",
      "source_type": "ai_act",
      "source_ref": "Article 26 AI Act",
      "description": "High-risk deployers using the system in the workplace should document notice to affected employees and workers' representatives.",
      "applies_when": "Declared EU-market high-risk deployer scenario with workplace deployment.",
      "source_ids": [
        "commission_navigating_ai_act",
        "eurlex_ai_act_regulation"
      ],
      "evidence_required": [
        "Employee or worker representative notice",
        "workplace deployment context",
        "before-use or pre-deployment notice language"
      ],
      "check_method": "File presence plus minimum content markers.",
      "blocking": true
    },
    {
      "control_id": "ai_act.article26.affected_person_notice_and_explanation",
      "title": "Article 26 affected-person notice and Article 86 explanation readiness",
      "source_type": "ai_act",
      "source_ref": "Article 26 / Article 86 AI Act",
      "description": "High-risk deployers making or assisting decisions about natural persons should document affected-person notice and, where legal or similarly significant effects arise, explanation handling.",
      "applies_when": "Declared EU-market high-risk deployer scenario with decision support affecting natural persons.",
      "source_ids": [
        "commission_navigating_ai_act",
        "eurlex_ai_act_regulation"
      ],
      "evidence_required": [
        "Affected person notice",
        "intended purpose statement",
        "decision-type disclosure",
        "explanation request procedure where legal or similarly significant effects apply"
      ],
      "check_method": "File presence plus minimum content markers.",
      "blocking": true
    },
    {
      "control_id": "ai_act.article26.public_authority_registration",
      "title": "Public-sector high-risk registration evidence",
      "source_type": "ai_act",
      "source_ref": "Article 26 / EU database registration",
      "description": "Public authorities deploying high-risk AI systems, or entities acting on their behalf, should retain evidence of the relevant EU database registration path where applicable.",
      "applies_when": "Declared EU-market high-risk deployer scenario in public-sector use outside the critical-infrastructure exception.",
      "source_ids": [
        "commission_navigating_ai_act",
        "eurlex_ai_act_regulation"
      ],
      "evidence_required": [
        "EU database registration record",
        "public or non-public registration path reference",
        "system or authority identifier"
      ],
      "check_method": "File presence plus minimum content markers.",
      "blocking": true
    },
    {
      "control_id": "vauban.readiness.provider_documentation",
      "title": "Provider documentation available",
      "source_type": "vauban_readiness",
      "source_ref": "Vauban readiness v1",
      "description": "Downstream deployers should retain provider-side documentation when building on third-party GPAI systems.",
